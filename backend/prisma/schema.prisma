// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Sighting {
  id             Int      @id @default(autoincrement())
  species        String
  scientificName String?
  location       String
  date           DateTime
  observer       String
  rarity         Int      @default(0) // ABA code (e.g., 4 or 5)
  details        String?
  mapUrl         String?
  checklistUrl   String?
  latitude       Float?
  longitude      Float?
  subId          String?
  locId          String?
  speciesCode    String?
  howMany        Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RarityCode {
  id             Int     @id @default(autoincrement())
  commonName     String  @unique // ABA common name
  scientificName String? @unique // ABA scientific name
  abaCode        Int     // ABA rarity code (1-6)
}

model IncomingEmail {
  id        Int      @id @default(autoincrement())
  messageId String   @unique
  subject   String?
  from      String?
  date      DateTime?
  rawBody   String
  status    String   @default("new") // new, processed, failed
  createdAt DateTime @default(now())
}
