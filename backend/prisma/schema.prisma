// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum IncidentStatus {
  OPEN
  CLOSED
  PERMANENTLY_CLOSED
}

model Sighting {
  id             Int       @id @default(autoincrement())
  species        String
  scientificName String?
  location       String
  date           DateTime
  observer       String
  rarity         Int       @default(0) // ABA code (e.g., 4 or 5)
  details        String?
  mapUrl         String?
  checklistUrl   String?
  latitude       Float?
  longitude      Float?
  subId          String?
  locId          String?
  speciesCode    String?
  howMany        Int?
  incidentId     String?
  incident       Incident? @relation(fields: [incidentId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Incident {
  id             String         @id @default(uuid())
  scientificName String
  commonName     String
  status         IncidentStatus @default(OPEN)
  minLat         Float
  maxLat         Float
  minLng         Float
  maxLng         Float
  firstSeen      DateTime
  lastSeen       DateTime
  closedAt       DateTime?
  sightingCount  Int            @default(1)
  primaryCounty  String?
  primaryState   String?
  primaryCountry String?
  statesCovered  String // JSON array of unique state/province names
  geminiSummary  String?
  summaryGeneratedAt DateTime?
  sightings      Sighting[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RarityCode {
  id             Int     @id @default(autoincrement())
  commonName     String  @unique // ABA common name
  scientificName String? @unique // ABA scientific name
  abaCode        Int     // ABA rarity code (1-6)
}

model IncomingEmail {
  id        Int      @id @default(autoincrement())
  messageId String   @unique
  subject   String?
  from      String?
  date      DateTime?
  rawBody   String
  status    String   @default("new") // new, processed, failed, processing
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model IngestionRun {
  id             String    @id @default(cuid())
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  status         String
  emailsFound    Int       @default(0)
  emailsIngested Int       @default(0)
  sightingsAdded Int       @default(0)
  errorMessage   String?
  trigger        String?

  @@index([startedAt])
}

model SpeciesPhoto {
  speciesName    String   @id
  photoUrl       String?
  attribution    String?
  fetchedAt      DateTime @default(now())
}
